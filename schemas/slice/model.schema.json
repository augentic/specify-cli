{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/augentic/specify-cli/schemas/slice/model.schema.json",
  "title": "Specify slice model.yaml",
  "description": "Validates a slice's single typed machine-readable model per RFC-29 \u00a7Typed slice model. This one schema validates both the agent's synthesis-response `model` and the persisted `model.yaml`: kernel-owned fields (`requirements[].id`, `.status`, `requirements[].sources`, `requirements[].resolution`, `claims[].winner`) and the header fields (`version`, `slice`, `target`, `project`) are optional so the agent may omit them and the kernel re-derives/stamps them on projection (normalize, never reject \u2014 there is no separate draft schema). Provenance is carried inline (`requirements[].claims[]` plus `resolution` / `resolution-trace`); there is no separate `provenance.yaml` file \u2014 `specrun slice provenance` projects the provenance view from this model on demand. Operators edit behavioral prose in `spec.md` / `design.md` / `tasks.md`; `model.yaml` is the machine view target builders consume. One slice binds one target (RFC-29 D5 \u00a7Per-slice fan-out) \u2014 `target` is a scalar, not an array. Kernel-rendered provenance lines in `spec.md` must match projected ids/status/source lists or `slice-spec-provenance-stale` fires; `slice-model-target-drift` checks the model's `target` against the target resolved from the slice's bound `project` (the plan no longer stores a per-slice `target`). Closed top-level shape \u2014 unknown fields are rejected.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "requirements",
    "domain",
    "apis",
    "configuration",
    "technical-logic",
    "observability",
    "tasks"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1
    },
    "slice": {
      "$ref": "#/$defs/kebabName"
    },
    "target": {
      "$ref": "#/$defs/targetRef"
    },
    "project": {
      "type": [
        "string",
        "null"
      ]
    },
    "requirements": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/modelRequirement"
      }
    },
    "domain": {
      "$ref": "#/$defs/modelDomain"
    },
    "apis": {
      "$ref": "#/$defs/modelApis"
    },
    "configuration": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/modelConfiguration"
      }
    },
    "technical-logic": {
      "$ref": "#/$defs/modelTechnicalLogic"
    },
    "observability": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/modelObservability"
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/modelTask"
      }
    }
  },
  "$defs": {
    "kebabName": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "claimId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*(\\.[a-z0-9]+(-[a-z0-9]+)*)*$",
      "description": "Dotted Evidence claim id (e.g. `password-reset.expiry`); mirrors the id grammar in `evidence.schema.json`."
    },
    "claimKind": {
      "type": "string",
      "enum": [
        "intent",
        "requirement",
        "criterion",
        "decision",
        "section",
        "diagram",
        "contract",
        "example",
        "excerpt",
        "type",
        "call",
        "region",
        "container",
        "leaf"
      ],
      "description": "Closed claim-kind enum mirrored byte-identically from `evidence.schema.json#/$defs/claimKind`. Carried on each `model.yaml` claim (D13) so the kernel resolves per-kind authority (\u00a7Authority over mixed-kind claims) without re-reading Evidence."
    },
    "reqId": {
      "type": "string",
      "pattern": "^REQ-[0-9]{3}$"
    },
    "taskId": {
      "type": "string",
      "pattern": "^TASK-[0-9]{3}$"
    },
    "decisionId": {
      "type": "string",
      "pattern": "^DEC-[0-9]{3}$"
    },
    "typeId": {
      "type": "string",
      "pattern": "^TYP-[0-9]{3}$"
    },
    "operationId": {
      "type": "string",
      "pattern": "^OP-[0-9]{3}$"
    },
    "configId": {
      "type": "string",
      "pattern": "^CFG-[0-9]{3}$"
    },
    "observabilityId": {
      "type": "string",
      "pattern": "^OBS-[0-9]{3}$"
    },
    "targetRef": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*@v\\d+$",
      "description": "The `name@vN` target-adapter pattern, resolved from the slice's bound project (the same pattern `registry.yaml` / `project.yaml.adapter` resolve to)."
    },
    "requirementStatus": {
      "type": "string",
      "enum": [
        "agreed",
        "unknown",
        "conflict",
        "divergence"
      ]
    },
    "agreementVerdict": {
      "type": "string",
      "enum": [
        "agreed",
        "disagreed"
      ],
      "description": "Agent-authored agreement verdict over the contributing claims. Required when more than one claim contributes; omitted for 0 or 1 claim. The kernel applies authority to it to derive `status` and winner markers but never re-decides whether two claim values mean the same thing."
    },
    "provenanceResolution": {
      "type": "string",
      "enum": [
        "single-source",
        "single-value-agreement",
        "authority-resolved",
        "per-slice-override",
        "unknown-no-evidence",
        "tied-conflict"
      ],
      "description": "Kernel-projected. How synthesis arrived at the requirement's final value, mirroring the provenance projection enum. `single-source` \u2014 one contributing claim. `single-value-agreement` \u2014 multiple contributors, identical value. `authority-resolved` \u2014 default authority ordering broke the tie. `per-slice-override` \u2014 the per-slice `authority-override` map picked the winner. `unknown-no-evidence` \u2014 no contributing claims (paired with `status: unknown`). `tied-conflict` \u2014 same-authority disagreement with no override (paired with `status: conflict`)."
    },
    "resolutionTrace": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "step"
      ],
      "properties": {
        "step": {
          "type": "string",
          "minLength": 1
        },
        "override": {
          "type": "object"
        },
        "winner": {
          "$ref": "#/$defs/kebabName"
        }
      },
      "description": "Kernel-projected. Optional trace describing how a non-trivial resolution selected the winning claim; present only when `resolution` is `authority-resolved` or `per-slice-override`."
    },
    "claimPath": {
      "type": "string",
      "pattern": "^[^\\s][^\\s]*(#L[1-9][0-9]*(-L[1-9][0-9]*)?)?$",
      "description": "Per-claim path anchor \u2014 `<path>`, `<path>#L<n>`, or `<path>#L<start>-L<end>` \u2014 mirrored from `evidence.schema.json#/$defs/claimPath`."
    },
    "modelRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "statement",
        "claims"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/reqId",
          "description": "Kernel-projected in declaration order. The agent omits it in the synthesis response; if present it is ignored and re-derived (normalize, never reject)."
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/requirementStatus",
          "description": "Kernel-projected from the claim count, the agent's `agreement` verdict, and resolved authority. The agent omits it; if present it is ignored and re-derived."
        },
        "agreement": {
          "$ref": "#/$defs/agreementVerdict"
        },
        "unit": {
          "$ref": "#/$defs/kebabName"
        },
        "claims": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/modelClaim"
          },
          "description": "Agent-authored claim-level provenance, carried inline (this replaces the former separate `provenance.yaml` `contributing-claims[]`): every `(source, id, kind)` claim that fed this requirement, winners and losers alike. Empty for an `unknown` requirement. `kind` (D13) lets the kernel resolve per-kind authority; the `winner` marker on each entry is kernel-projected."
        },
        "sources": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/kebabName"
          },
          "description": "Kernel-projected rendered source list (highest authority first), mirroring the `Sources:` line rendered into `spec.md`. The agent omits it."
        },
        "resolution": {
          "$ref": "#/$defs/provenanceResolution"
        },
        "resolution-trace": {
          "$ref": "#/$defs/resolutionTrace"
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "scenarios": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "modelClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "id",
        "kind"
      ],
      "properties": {
        "source": {
          "$ref": "#/$defs/kebabName"
        },
        "id": {
          "$ref": "#/$defs/claimId"
        },
        "kind": {
          "$ref": "#/$defs/claimKind",
          "description": "Agent-authored: the kind of the cited Evidence claim (D13). The kernel uses it to apply per-kind authority (\u00a7Authority over mixed-kind claims) without re-reading Evidence. `slice-model-claim-kind-mismatch` rejects a value that disagrees with the kind recorded for that `(source, id)` in Evidence."
        },
        "value": {
          "type": "string",
          "description": "Kernel-projected. Optional single-line claim payload copied from the source Evidence claim for the inline provenance view (truncated to the first non-empty line with a trailing ellipsis when multi-line). The agent omits it."
        },
        "path": {
          "$ref": "#/$defs/claimPath",
          "description": "Kernel-projected. Optional `<path>#L<n>` anchor copied from the source Evidence claim so an operator can open the original line range. The agent omits it."
        },
        "winner": {
          "type": "boolean",
          "description": "Kernel-projected. Present (`true` on the authority-resolved winner, `false` on every dropped loser) only for a `divergence` requirement; absent for `agreed` and `conflict` requirements."
        }
      }
    },
    "modelDomain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "types"
      ],
      "properties": {
        "types": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "name",
              "fields"
            ],
            "properties": {
              "id": {
                "$ref": "#/$defs/typeId"
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "kind": {
                "type": "string",
                "enum": [
                  "record",
                  "enum",
                  "alias",
                  "newtype"
                ],
                "default": "record"
              },
              "fields": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "name",
                    "type"
                  ],
                  "properties": {
                    "name": {
                      "type": "string",
                      "minLength": 1
                    },
                    "type": {
                      "type": "string",
                      "minLength": 1
                    },
                    "optional": {
                      "type": "boolean",
                      "default": false
                    },
                    "description": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "modelApis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surfaces"
      ],
      "properties": {
        "surfaces": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "kind",
              "operations"
            ],
            "properties": {
              "id": {
                "$ref": "#/$defs/kebabName"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "rest",
                  "graphql",
                  "grpc",
                  "asyncapi",
                  "cli",
                  "library",
                  "ui"
                ]
              },
              "operations": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "id",
                    "name"
                  ],
                  "properties": {
                    "id": {
                      "$ref": "#/$defs/operationId"
                    },
                    "name": {
                      "type": "string",
                      "minLength": 1
                    },
                    "request": {
                      "type": "string"
                    },
                    "response": {
                      "type": "string"
                    },
                    "errors": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "satisfies": {
                      "type": "array",
                      "uniqueItems": true,
                      "items": {
                        "$ref": "#/$defs/reqId"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "modelConfiguration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "key",
        "type"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/configId"
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "default": {
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "type": "string"
        }
      }
    },
    "modelTechnicalLogic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decisions"
      ],
      "properties": {
        "decisions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "statement"
            ],
            "properties": {
              "id": {
                "$ref": "#/$defs/decisionId"
              },
              "statement": {
                "type": "string",
                "minLength": 1
              },
              "rationale": {
                "type": "string"
              },
              "satisfies": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "$ref": "#/$defs/reqId"
                }
              }
            }
          }
        }
      }
    },
    "modelObservability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "name"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/observabilityId"
        },
        "kind": {
          "type": "string",
          "enum": [
            "metric",
            "trace",
            "log",
            "alert"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      }
    },
    "modelTask": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "text"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/taskId"
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "depends-on": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/taskId"
          }
        },
        "satisfies": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/reqId"
          }
        }
      }
    }
  }
}
