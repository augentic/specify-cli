{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specify.cli/schemas/contract/dump.schema.json",
  "title": "specify contract dump payload",
  "description": "Machine-readable CLI contract: the verb tree, exit codes, error discriminants, journal event ids, embedded schema paths, and the build-time tests/ inventory one specify binary exposes. Consumed by the cli-contract lint kind to cross-check documentation and skill prose against the live surface.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "binary-version",
    "commands",
    "exit-codes",
    "error-ids",
    "journal-event-ids",
    "schemas",
    "tests"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "binary-version": {
      "type": "string",
      "minLength": 1
    },
    "commands": {
      "$ref": "#/$defs/commandNode"
    },
    "exit-codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/exitCode"
      }
    },
    "error-ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
      }
    },
    "journal-event-ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(-[a-z0-9]+)*(\\.[a-z0-9]+(-[a-z0-9]+)*)*$"
      }
    },
    "schemas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^tests/.+$"
      }
    }
  },
  "$defs": {
    "commandNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "args",
        "subcommands"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "about": {
          "type": "string"
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "subcommands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/commandNode"
          }
        }
      }
    },
    "exitCode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "name",
        "meaning"
      ],
      "properties": {
        "code": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "meaning": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
