{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/augentic/specify/schemas/schema.schema.json",
  "title": "Specify schema.yaml",
  "description": "Validates the structure of a Specify schema definition file.",
  "type": "object",
  "required": ["name", "version", "description", "pipeline"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Schema identifier (e.g., omnia)."
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version number."
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of the schema."
    },
    "extends": {
      "type": "string",
      "description": "URL of parent schema for composition."
    },
    "domain": {
      "type": "string",
      "description": "Default project context: tech stack, architecture, testing approach."
    },
    "pipeline": {
      "type": "object",
      "required": ["define", "build", "merge"],
      "additionalProperties": false,
      "description": "Pipeline phases with brief references.",
      "properties": {
        "define": {
          "type": "array",
          "minItems": 1,
          "description": "Ordered list of define-phase briefs.",
          "items": { "$ref": "#/$defs/pipelineEntry" }
        },
        "build": {
          "type": "array",
          "minItems": 1,
          "description": "Build-phase briefs.",
          "items": { "$ref": "#/$defs/pipelineEntry" }
        },
        "merge": {
          "type": "array",
          "minItems": 1,
          "description": "Merge-phase briefs.",
          "items": { "$ref": "#/$defs/pipelineEntry" }
        }
      }
    }
  },
  "$defs": {
    "pipelineEntry": {
      "type": "object",
      "required": ["id", "brief"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Brief identifier (e.g., proposal, specs, design, tasks, build, merge)."
        },
        "brief": {
          "type": "string",
          "description": "Relative path to the brief markdown file with YAML frontmatter."
        }
      }
    }
  }
}
