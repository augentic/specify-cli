{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/augentic/specify-cli/schemas/authoring/marketplace.schema.json",
  "title": "Cursor plugin marketplace manifest",
  "description": "Validates `.cursor-plugin/marketplace.json`. Cross-file consistency with `plugins/` (symlink integrity, declared plugin surfaces) is enforced by `specify lint framework`.",
  "type": "object",
  "required": ["name", "owner", "metadata", "plugins"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Editor schema hint; ignored by specify lint framework semantics."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Marketplace identifier."
    },
    "owner": {
      "type": "object",
      "required": ["name", "email"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string",
          "format": "email"
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["description", "version", "pluginRoot"],
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
          "description": "Semantic version string for the marketplace bundle."
        },
        "pluginRoot": {
          "type": "string",
          "const": "plugins",
          "description": "Relative path from the repo root to plugin directories."
        }
      }
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "source", "description"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$",
            "description": "Plugin display name."
          },
          "source": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$",
            "description": "Directory name under `plugins/`."
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "description": "Short human-readable plugin summary."
          }
        }
      }
    }
  }
}
