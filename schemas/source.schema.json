{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/augentic/specify-cli/schemas/source.schema.json",
  "title": "Specify source adapter manifest",
  "description": "Refines `adapter.schema.json` for source adapters per workflow §Source adapter contract. Locks `axis` to the literal `source` and requires both `briefs.extract` and `briefs.survey` — together these close the operation set to `{extract, survey}` (the canonical iterator is `briefs.keys()`). The `kebabName` and `toolDeclaration` `$defs` are intentionally inlined (rather than `$ref`-resolved against `adapter.schema.json`) so the schema compiles without a registry lookup; the embedded `name` pattern MUST stay byte-identical to `adapter.schema.json#/$defs/kebabName.pattern`.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "version", "axis", "description", "briefs", "execution"],
  "properties": {
    "name": { "$ref": "#/$defs/kebabName" },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$"
    },
    "axis": {
      "type": "string",
      "const": "source",
      "description": "Locked to `source` for source-adapter manifests."
    },
    "briefs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["extract", "survey"],
      "properties": {
        "survey": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?![A-Za-z][A-Za-z0-9+.-]*://).+$"
        },
        "extract": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?![A-Za-z][A-Za-z0-9+.-]*://).+$"
        }
      }
    },
    "tools": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/toolDeclaration" }
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "execution": {
      "type": "string",
      "enum": ["agent"],
      "description": "Closed adapter execution mode. Source adapters are agent-only: `survey` and `extract` run as two-phase agent handoffs."
    }
  },
  "$defs": {
    "kebabName": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "toolDeclaration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "$ref": "#/$defs/kebabName" },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9A-Za-z.-]+)?$"
        },
        "permissions": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
