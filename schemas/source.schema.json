{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/augentic/specify-cli/schemas/source.schema.json",
  "title": "Specify source adapter manifest",
  "description": "Refines `plugin.schema.json` for source adapters per RFC-25 §Source adapter contract. Locks `axis` to the literal `source`, locks `operations` to the closed set `[enumerate, extract]`, and requires both `briefs.enumerate` and `briefs.extract`. The `kebabName` and `toolDeclaration` `$defs` are intentionally inlined (rather than `$ref`-resolved against `plugin.schema.json`) so the schema compiles without a registry lookup; the embedded `name` pattern MUST stay byte-identical to `plugin.schema.json#/$defs/kebabName.pattern`.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "version", "axis", "operations", "briefs"],
  "properties": {
    "name": { "$ref": "#/$defs/kebabName" },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "axis": {
      "type": "string",
      "const": "source",
      "description": "Locked to `source` for source-adapter manifests."
    },
    "operations": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "string",
        "enum": ["enumerate", "extract"]
      },
      "description": "Closed set: source adapters declare exactly `enumerate` and `extract` in any order."
    },
    "briefs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enumerate", "extract"],
      "properties": {
        "enumerate": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?![A-Za-z][A-Za-z0-9+.-]*://).+$"
        },
        "extract": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?![A-Za-z][A-Za-z0-9+.-]*://).+$"
        }
      }
    },
    "tools": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/toolDeclaration" }
    },
    "description": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "kebabName": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "toolDeclaration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "$ref": "#/$defs/kebabName" },
        "version": { "type": "string", "minLength": 1 },
        "permissions": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
